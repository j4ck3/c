# Copy to .env and set your Netbird public hostname.
# Used by docker-compose for Traefik Host() rules.
# NETBIRD_DOMAIN=netbird.hjacke.com

# Netbird client (netbird-client service). Create a setup key in Dashboard → Setup Keys.
# NB_SETUP_KEY=your_setup_key_here
# NETBIRD_CLIENT_HOSTNAME=node_name