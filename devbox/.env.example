# Dev Container Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# OpenCode Configuration
# ============================================
# OpenCode uses Antigravity refresh tokens which are automatically
# mounted from ~/.config/opencode/antigravity-accounts.json
# No environment variables needed for OpenCode auth.

# ============================================
# Docker Hub Authentication
# ============================================
# Option 1: Username and password
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password

# Option 2: Username and access token (recommended)
# DOCKER_USERNAME=your-docker-username
# DOCKER_TOKEN=your-docker-access-token

# Private Docker registry (optional)
# DOCKER_REGISTRY_URL=registry.example.com
# DOCKER_REGISTRY_USERNAME=your-registry-username
# DOCKER_REGISTRY_PASSWORD=your-registry-password

# ============================================
# GitHub & GitLab Authentication
# ============================================
# Authentication via SSH keys (automatically mounted from ~/.ssh)
# Ensure your SSH keys are configured on your host:
#   ~/.ssh/id_rsa or ~/.ssh/id_ed25519 (private key)
#   ~/.ssh/id_rsa.pub or ~/.ssh/id_ed25519.pub (public key)
#
# Add your public key to GitHub: https://github.com/settings/keys
# Add your public key to GitLab: https://gitlab.com/-/profile/keys
#
# GitLab URL (if using self-hosted GitLab, default: gitlab.com)
# GITLAB_URL=gitlab.example.com

# ============================================
# Docker Configuration
# ============================================
# Docker group ID on your host system
# Find with: getent group docker | cut -d: -f3
DOCKER_GID=999

# ============================================
# BasicAuth for Remote Access (Traefik)
# ============================================
# REQUIRED for remote profile!
#
# Generate password hash with:
#   htpasswd -nb jacke yourpassword
# 
# Or use Docker:
#   docker run --rm httpd:2.4-alpine htpasswd -nb jacke yourpassword
#
# IMPORTANT: Dollar signs must be doubled ($$) in docker-compose!
# Example: if htpasswd outputs:  jacke:$apr1$xyz$abc
# You must write it as:          jacke:$$apr1$$xyz$$abc
#
DEVBOX_AUTH_USERS=jacke:$$apr1$$CHANGEME$$CHANGEME

# ============================================
# Auto-Clone Repositories
# ============================================
# Automatically clone repositories into /workspace on container start
# Format: Comma-separated list of repositories
# 
# Supported formats:
#   Short format (GitHub assumed): user/repo
#   Short format (GitLab): gitlab.com/username/repo or username/repo (if GITLAB_URL is set)
#   Full SSH URLs: git@github.com:user/repo.git, git@gitlab.com:user/repo.git
#   Mixed formats are supported
#
# Examples:
#   GitHub: AUTO_CLONE_REPOS=j4ck3/dotfiles,octocat/Hello-World
#   GitLab: AUTO_CLONE_REPOS=gitlab.com/username/project,another/repo
#   Mixed: AUTO_CLONE_REPOS=j4ck3/dotfiles,gitlab.com/company/private-repo,git@github.com:user/repo.git
#
# Note: Repositories are cloned to /workspace/<repo-name>
# Already cloned repos are skipped automatically
#
# AUTO_CLONE_REPOS=j4ck3/dotfiles,gitlab.com/username/project
