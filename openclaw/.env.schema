# @defaultSensitive=false @defaultRequired=infer
# @plugin(@varlock/bitwarden-plugin@0.0.3)
# @initBitwarden(accessToken=$BITWARDEN_ACCESS_TOKEN)
# ---

# Bitwarden Secrets Manager machine account access token.
# This is the ONLY secret stored locally — all others are fetched from Bitwarden at runtime.
# Create a machine account at: https://vault.bitwarden.com → Secrets Manager → Machine accounts
# @type=bitwardenAccessToken @sensitive @required
BITWARDEN_ACCESS_TOKEN=

# OpenAI API key — powers OpenClaw AI and OpenViking embeddings/VLM.
# Store in Bitwarden SM and replace the UUID below with the real secret ID.
# @sensitive @required @type=string(startsWith=sk-)
OPENAI_API_KEY=bitwarden("a7b997cd-3fd7-49d9-ba1c-b40c00fef137")

# OpenClaw gateway authentication token
# @sensitive @required
OPENCLAW_GATEWAY_TOKEN=bitwarden("73d4127a-6057-40c4-9788-b40c00fed7a7")

# Telegram bot token (from @BotFather)
# @sensitive
TELEGRAM_BOT_TOKEN=bitwarden("1070cb2b-e535-4df8-9ce9-b40c00feb2ed")

# Home Assistant URL (non-sensitive, set directly)
# @type=url @required
HA_URL=http://10.0.0.23:8123

# Home Assistant long-lived access token
# @sensitive @required
HA_TOKEN=bitwarden("83bc0e17-cf11-47fa-b829-b40c00fe8874")

# Aliases (same values) — some docs/tools expect HOME_ASSISTANT_* names
# @type=url @required
HOME_ASSISTANT_URL=http://10.0.0.23:8123
# @sensitive @required
HOME_ASSISTANT_TOKEN=bitwarden("83bc0e17-cf11-47fa-b829-b40c00fe8874")